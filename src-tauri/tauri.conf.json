{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Douyin Stream Downloader",
  "version": "0.1.0",
  "identifier": "com.cjpro.douyin.downloader",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Douyin M3U8 Downloader",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
